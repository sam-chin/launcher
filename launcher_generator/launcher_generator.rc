#include "resource.h"

IDD_GENERATOR_DIALOG DIALOGEX 0, 0, 450, 350
STYLE DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "登录器生成器"
FONT 9, "宋体"
BEGIN
    GROUPBOX        "网站配置",IDC_STATIC,7,7,436,100
    LTEXT           "官网:",IDC_STATIC,15,22,40,10
    EDITTEXT        IDC_WEBSITE_EDIT,60,20,376,12,ES_AUTOHSCROLL
    LTEXT           "充值:",IDC_STATIC,15,42,40,10
    EDITTEXT        IDC_RECHARGE_EDIT,60,40,376,12,ES_AUTOHSCROLL
    LTEXT           "客服:",IDC_STATIC,15,62,40,10
    EDITTEXT        IDC_SUPPORT_EDIT,60,60,376,12,ES_AUTOHSCROLL
    LTEXT           "注册:",IDC_STATIC,15,82,40,10
    EDITTEXT        IDC_REGISTER_EDIT,60,80,376,12,ES_AUTOHSCROLL

    GROUPBOX        "补丁与服务器配置",IDC_STATIC,7,112,436,80
    LTEXT           "服务器列表:",IDC_STATIC,15,127,60,10
    EDITTEXT        IDC_SERVER_LIST_EDIT,80,125,356,12,ES_AUTOHSCROLL
    LTEXT           "补丁路径:",IDC_STATIC,15,147,60,10
    EDITTEXT        IDC_PATCH_EDIT,80,145,356,12,ES_AUTOHSCROLL
    LTEXT           "补丁密钥:",IDC_STATIC,15,167,60,10
    EDITTEXT        IDC_PATCH_KEY_EDIT,80,165,356,12,ES_AUTOHSCROLL

    GROUPBOX        "客户端配置",IDC_STATIC,7,197,436,50
    LTEXT           "客户端:",IDC_STATIC,15,212,60,10
    EDITTEXT        IDC_CLIENT_EDIT,80,210,356,12,ES_AUTOHSCROLL

    PUSHBUTTON      "保存配置",IDC_SAVE_BTN,15,257,100,25
    PUSHBUTTON      "加载配置",IDC_LOAD_BTN,122,257,100,25
    DEFPUSHBUTTON   "生成登录器",IDC_GENERATE_BTN,229,257,100,25
    PUSHBUTTON      "打开目录",IDC_OPEN_DIR_BTN,336,257,100,25
END
